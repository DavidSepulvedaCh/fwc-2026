DATABASE_URL="postgresql://user:password@127.0.0.1:5432/fwc_2026?schema=public"

# URL pública canónica del sitio (sin slash final). Se usa para metadata SEO,
# sitemap.xml, robots.txt y enlaces absolutos en OpenGraph/Twitter cards.
NEXT_PUBLIC_SITE_URL=""

# -----------------------------------------------------------------------------
# Autenticación (NextAuth v5)
# -----------------------------------------------------------------------------
# Secreto usado para firmar cookies/JWT. Genera uno con: npx auth secret
AUTH_SECRET=""

# URL pública del sitio en producción (NextAuth la usa para callbacks OAuth).
# En desarrollo puede omitirse y NextAuth usará http://localhost:3000.
# AUTH_URL="https://polla-mundial-2026.com"

# Google OAuth 2.0 — Credenciales desde Google Cloud Console → APIs & Services
# → Credentials → OAuth 2.0 Client ID (Web application).
# Redirect URIs autorizadas:
#   http://localhost:3000/api/auth/callback/google
#   https://<tu-dominio>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
